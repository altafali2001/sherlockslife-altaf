generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Application {
  id                 String   @id @default(cuid())
  email              String
  phone              String?
  about              String
  createdAt          DateTime @default(now())
  acceptedTerms      Boolean
  averageViews       String?
  city               String?
  contentNiche       String
  country            String
  creatorHandle      String
  firstName          String
  followersRange     String
  heardFrom          String?
  interestedIn       Json
  lastName           String
  mediaConsent       Boolean
  newsletter         Boolean
  otherSocialLinks   String?
  previousExperience String?
  primaryPlatforms   Json
  primaryProfileLink String
  updatedAt          DateTime @updatedAt
}
